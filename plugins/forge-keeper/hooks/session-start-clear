#!/usr/bin/env bash
# SessionStart(clear) context rescue for forge-keeper.
#
# Replaces the original `type: "prompt"` hook, which fails with
# "ToolUseContext is required for prompt hooks" on SessionStart events.
# Same idea as forge-superpowers/session-start: gather signals in bash,
# inject them via hookSpecificOutput.additionalContext.

set -uo pipefail
trap 'exit 0' ERR

PROJECT_ROOT="${CLAUDE_PROJECT_DIR:-$PWD}"
cd "$PROJECT_ROOT" 2>/dev/null || {
  printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"forge-keeper: could not access project root."}}\n'
  exit 0
}

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

emit() {
  local escaped
  escaped=$(escape_for_json "$1")
  printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$escaped"
  exit 0
}

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  emit "[forge-keeper] /clear detected. Not in a git repo — no rescue context to gather."
fi

unstaged=$(git diff --name-only 2>/dev/null | wc -l | tr -d ' ')
staged=$(git diff --cached --name-only 2>/dev/null | wc -l | tr -d ' ')
untracked=$(git ls-files --others --exclude-standard 2>/dev/null | wc -l | tr -d ' ')
recent_commits=$(git log --oneline -5 2>/dev/null || true)

latest_session=""
session_age_hours=""
if [ -d "docs/sessions" ]; then
  latest_session=$(find docs/sessions -maxdepth 1 -type f -name '*.md' -print0 2>/dev/null \
    | xargs -0 ls -t 2>/dev/null \
    | head -1 || true)
  if [ -n "$latest_session" ]; then
    mtime=$(stat -f %m "$latest_session" 2>/dev/null || stat -c %Y "$latest_session" 2>/dev/null || echo 0)
    if [ "$mtime" -gt 0 ]; then
      now=$(date +%s)
      session_age_hours=$(( (now - mtime) / 3600 ))
    fi
  fi
fi

dirty=$(( unstaged + staged + untracked ))

summary="<forge-keeper-rescue>
[forge-keeper] /clear detected — best-effort context rescue from durable sources.
"

if [ -n "$latest_session" ]; then
  summary+="Last session log: $(basename "$latest_session")"
  [ -n "$session_age_hours" ] && summary+=" (${session_age_hours}h ago)"
  summary+="
"
else
  summary+="No session logs found in docs/sessions/.
"
fi

if [ "$dirty" -gt 0 ]; then
  summary+="Working tree: ${unstaged} unstaged, ${staged} staged, ${untracked} untracked.
WARNING: unsaved work at risk. Consider /forge-keeper:sync to capture context from git state.
"
else
  summary+="Working tree clean.
"
fi

if [ -n "$recent_commits" ]; then
  summary+="
Recent commits:
${recent_commits}
"
fi

summary+="
If the user's next message references prior work, read the latest session log before answering.
</forge-keeper-rescue>"

emit "$summary"
