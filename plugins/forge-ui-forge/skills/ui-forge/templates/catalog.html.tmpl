<!doctype html>
<!--
  ui-forge — registry catalog
  Regenerate on Phase 4. Placeholders:
    {{PROJECT_NAME}}, {{COMPONENT_COUNT}}, {{FIXTURE_COUNT}}, {{SCREEN_COUNT}},
    {{COMPONENT_CARDS}}, {{FIXTURE_ROWS}}, {{SCREEN_ROWS}}, {{TAGS_JSON}}

  Each component card MUST embed its latest component.html via <iframe srcdoc="..."> (escape HTML).
-->
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{{PROJECT_NAME}} · component catalog</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      body { background: #f8fafc; }
      .tag-chip {
        display: inline-block; padding: 2px 8px; border-radius: 9999px;
        background: #e2e8f0; color: #334155; font-size: 11px; font-weight: 500;
        margin-right: 4px; margin-bottom: 4px; cursor: pointer;
      }
      .tag-chip.active { background: #3b82f6; color: white; }
      .component-card { transition: opacity .15s ease; }
      .component-card.hidden { display: none; }
      .preview-frame {
        width: 100%; height: 240px; border: none;
        background: white; border-radius: 0.375rem; overflow: hidden;
      }
    </style>
  </head>
  <body class="font-sans text-slate-900">
    <header class="max-w-7xl mx-auto px-6 py-8 border-b border-slate-200">
      <h1 class="text-3xl font-bold">{{PROJECT_NAME}} · catalog</h1>
      <p class="text-slate-500 mt-1">
        {{COMPONENT_COUNT}} components · {{FIXTURE_COUNT}} fixtures · {{SCREEN_COUNT}} screens.
      </p>
      <div id="tag-filters" class="mt-4">
        <span class="tag-chip active" data-tag="*">all</span>
{{TAG_CHIPS}}
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-8 space-y-12">
      <section>
        <h2 class="text-xl font-semibold mb-4">Components</h2>
        <div id="components-grid" class="grid gap-6 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
{{COMPONENT_CARDS}}
        </div>
      </section>

      <section>
        <h2 class="text-xl font-semibold mb-4">Fixtures</h2>
        <table class="w-full text-sm border-collapse">
          <thead class="text-left text-slate-500 border-b border-slate-200">
            <tr><th class="py-2">Name</th><th>Description</th><th>Used in screens</th></tr>
          </thead>
          <tbody>
{{FIXTURE_ROWS}}
          </tbody>
        </table>
      </section>

      <section>
        <h2 class="text-xl font-semibold mb-4">Screens</h2>
        <table class="w-full text-sm border-collapse">
          <thead class="text-left text-slate-500 border-b border-slate-200">
            <tr><th class="py-2">Screen</th><th>Components used</th><th>Last updated</th></tr>
          </thead>
          <tbody>
{{SCREEN_ROWS}}
          </tbody>
        </table>
      </section>
    </main>

    <footer class="max-w-7xl mx-auto px-6 py-8 text-xs text-slate-400">
      Generated by ui-forge.
    </footer>

    <script>
      (function () {
        const chips = document.querySelectorAll('#tag-filters .tag-chip');
        const cards = document.querySelectorAll('#components-grid .component-card');
        chips.forEach((chip) => {
          chip.addEventListener('click', () => {
            chips.forEach((c) => c.classList.remove('active'));
            chip.classList.add('active');
            const tag = chip.dataset.tag;
            cards.forEach((card) => {
              if (tag === '*') { card.classList.remove('hidden'); return; }
              const cardTags = (card.dataset.tags || '').split(',');
              card.classList.toggle('hidden', !cardTags.includes(tag));
            });
          });
        });
      })();
    </script>
  </body>
</html>
