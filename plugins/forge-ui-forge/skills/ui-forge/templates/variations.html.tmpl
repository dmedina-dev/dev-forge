<!doctype html>
<!--
  ui-forge — Phase 2 · variations grid
  Fill placeholders: {{SCREEN_ID}}, {{SCREEN_TITLE}}, {{VARIANT_COUNT}}, {{VARIANT_CARDS}}, {{MOCK_DATA_JSON}}

  Each variant card MUST:
    - Wrap its content inside a fixed-size container so all variants share identical viewport dimensions (e.g., 1280×800 or the target screen's viewport).
    - Carry data-variant-id="NN" on the outer <article>.
    - Pull its data from the shared <script id="uiforge-mock"> JSON (document.getElementById('uiforge-mock')).

  Reused registry components stay identical across cards; variation happens in the new blocks and the global composition.
-->
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{{SCREEN_TITLE}} · variations</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      body { background: #f8fafc; }
      .variant-frame {
        width: 1280px; height: 800px;
        overflow: hidden; background: white;
        border-radius: 0.5rem; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        transform-origin: top left;
      }
      @media (max-width: 1400px) { .variant-frame { transform: scale(0.6); } }
      @media (max-width: 900px) { .variant-frame { transform: scale(0.45); } }
      .variant-card {
        position: relative; padding: 2rem; display: flex; flex-direction: column; gap: 0.75rem;
      }
      .variant-badge {
        position: absolute; top: 12px; left: 12px; z-index: 10;
        background: #0f172a; color: white; padding: 4px 10px;
        border-radius: 9999px; font-size: 12px; font-weight: 600;
        font-family: ui-monospace, monospace;
      }
    </style>
  </head>
  <body class="font-sans text-slate-900">
    <header class="max-w-7xl mx-auto px-6 py-8">
      <h1 class="text-3xl font-bold">{{SCREEN_TITLE}}</h1>
      <p class="text-slate-500 mt-1">
        Screen: <code class="bg-slate-100 px-2 py-0.5 rounded">{{SCREEN_ID}}</code> ·
        {{VARIANT_COUNT}} variations · same mock data · same viewport.
      </p>
      <p class="text-sm text-slate-400 mt-2">
        Choose a winner: reply with <code>id: NN</code> or <code>mix: A+B</code>.
      </p>
    </header>

    <script id="uiforge-mock" type="application/json">
{{MOCK_DATA_JSON}}
    </script>

    <main class="max-w-[2800px] mx-auto px-6 grid gap-8 grid-cols-1 md:grid-cols-2 xl:grid-cols-3">
{{VARIANT_CARDS}}
    </main>

    <footer class="max-w-7xl mx-auto px-6 py-12 text-xs text-slate-400">
      Generated by ui-forge · Phase 2 · {{SCREEN_ID}}
    </footer>
  </body>
</html>
