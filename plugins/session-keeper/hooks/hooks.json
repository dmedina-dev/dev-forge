{
  "description": "Context-aware safety net that monitors git activity and reminds to sync when thresholds are exceeded",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/context-watch.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
